{
  "name": "country-flag-kit",
  "version": "1.0.0",
  "description": "271 country flags (SVG, 4:3 + 1:1) plus flag emoji and international dial codes — a small ISO-3166 country dataset for phone inputs and country pickers.",
  "keywords": [
    "flags",
    "country-flags",
    "svg",
    "flag-icons",
    "iso-3166",
    "emoji",
    "flag-emoji",
    "dial-code",
    "calling-code",
    "phone-code",
    "country-data",
    "country-picker",
    "4x3",
    "1x1"
  ],
  "license": "MIT",
  "author": "YOUR_NAME",
  "homepage": "https://github.com/YOUR_GITHUB_HANDLE/country-flag-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_GITHUB_HANDLE/country-flag-kit.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB_HANDLE/country-flag-kit/issues"
  },
  "main": "index.json",
  "exports": {
    ".": "./index.json",
    "./index.json": "./index.json",
    "./4x3/*": "./4x3/*",
    "./1x1/*": "./1x1/*"
  },
  "files": [
    "4x3",
    "1x1",
    "index.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "private": false
}
